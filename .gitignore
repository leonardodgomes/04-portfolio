# --- Power BI ---
# Ignora o arquivo pesado do relatório (evita o limite do GitHub/Databricks)
powerbi/*.pbix

# Ignora arquivos de template e configurações locais do Power BI Desktop
powerbi/*.pbit
powerbi/.User.twb
powerbi/ExecutionCache/

# --- Desenvolvimento / Sandbox / Rascunhos ---
# Bloqueia a pasta de testes para não poluir o repositório oficial
src/00_sandbox/

# --- Databricks / Python / Sistema ---
# Ignora arquivos temporários ocultos do sistema e das IDEs
.DS_Store
Thumbs.db
*.tmp
.databricks/
.idea/
.vscode/

# --- Segurança ---
# Bloqueia arquivos de credenciais, senhas ou tokens locais
*.env
secrets.json
